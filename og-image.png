<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8"/>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{width:1200px;height:630px;overflow:hidden;background:#0a0a0f;font-family:'DM Sans',sans-serif;}
.wrap{
  width:1200px;height:630px;position:relative;
  background:
    radial-gradient(ellipse at 80% 50%, rgba(78,207,122,.18), transparent 52%),
    radial-gradient(ellipse at 20% 80%, rgba(78,207,122,.07), transparent 45%),
    linear-gradient(135deg,#0a0a0f 0%,#0d0d14 100%);
  display:flex;align-items:center;
}

/* left content */
.left{
  flex:1;
  padding:0 0 0 96px;
  display:flex;flex-direction:column;
  gap:0;
  z-index:2;
}
.logo-row{
  display:flex;align-items:center;gap:14px;
  margin-bottom:36px;
}
.logo-text{
  font-family:'Outfit',sans-serif;
  font-size:28px;font-weight:800;
  color:rgba(240,237,232,0.4);
  letter-spacing:-0.5px;
}
.logo-text span{color:#4ecf7a;}

.badge{
  display:inline-block;
  border:1px solid rgba(78,207,122,.4);
  color:#4ecf7a;
  font-size:11px;letter-spacing:1.8px;
  text-transform:uppercase;
  padding:6px 18px;border-radius:999px;
  margin-bottom:22px;
  width:fit-content;
}
h1{
  font-family:'Outfit',sans-serif;
  font-size:58px;font-weight:800;
  line-height:1.04;letter-spacing:-2px;
  color:#f0ede8;
  margin-bottom:20px;
  max-width:520px;
}
h1 em{font-style:normal;color:#4ecf7a;}
.sub{
  font-size:18px;font-weight:400;
  color:rgba(240,237,232,.55);
  line-height:1.6;
  max-width:440px;
  margin-bottom:36px;
}
.pills{
  display:flex;gap:10px;flex-wrap:wrap;
}
.pill{
  background:rgba(78,207,122,.08);
  border:1px solid rgba(78,207,122,.22);
  color:rgba(240,237,232,.7);
  font-size:12px;letter-spacing:.6px;
  padding:7px 16px;border-radius:999px;
}
.pill strong{color:#4ecf7a;font-weight:500;}

/* right radar */
.right{
  width:460px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  padding-right:80px;
  z-index:2;
}

/* decorative grid lines */
.grid-line{
  position:absolute;
  background:rgba(255,255,255,.025);
}
.gl-h{left:0;right:0;height:1px;}
.gl-v{top:0;bottom:0;width:1px;}

/* url strip */
.url-strip{
  position:absolute;
  bottom:32px;left:96px;
  font-size:13px;color:rgba(240,237,232,.22);
  letter-spacing:.5px;
}
</style>
</head>
<body>
<div class="wrap">

  <!-- subtle grid lines -->
  <div class="grid-line gl-h" style="top:210px;"></div>
  <div class="grid-line gl-h" style="top:420px;"></div>
  <div class="grid-line gl-v" style="left:740px;"></div>

  <div class="left">
    <div class="logo-row">
      <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="44" fill="none" stroke="#4ecf7a" stroke-width="6"/>
        <circle cx="50" cy="50" r="29" fill="none" stroke="#4ecf7a" stroke-width="4" opacity=".6"/>
        <circle cx="50" cy="50" r="14" fill="none" stroke="#4ecf7a" stroke-width="3" opacity=".35"/>
        <line x1="50" y1="50" x2="84" y2="18" stroke="#4ecf7a" stroke-width="5" stroke-linecap="round"/>
        <circle cx="50" cy="50" r="5" fill="#4ecf7a"/>
      </svg>
      <div class="logo-text">ThePeptide<span>Radar</span></div>
    </div>

    <div class="badge">Independent Directory</div>

    <h1>Find suppliers you can <em>actually trust</em></h1>

    <p class="sub">Verified peptide suppliers filtered by country — no ads, no paid placements.</p>

    <div class="pills">
      <div class="pill"><strong>✓</strong> Community reviewed</div>
      <div class="pill"><strong>✓</strong> Country filtered</div>
      <div class="pill"><strong>✓</strong> Lab tested only</div>
    </div>
  </div>

  <div class="right">
    <svg width="320" height="320" viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="bgGrad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(0,38,20,0.97)"/>
          <stop offset="50%" stop-color="rgba(0,20,10,0.98)"/>
          <stop offset="100%" stop-color="rgba(0,8,4,1)"/>
        </radialGradient>
        <radialGradient id="glowGrad" cx="50%" cy="50%" r="50%">
          <stop offset="70%" stop-color="rgba(78,207,122,0.15)"/>
          <stop offset="100%" stop-color="rgba(78,207,122,0)"/>
        </radialGradient>
        <clipPath id="circle-clip">
          <circle cx="160" cy="160" r="144"/>
        </clipPath>
        <!-- sweep gradient -->
        <linearGradient id="sweepFade" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(78,207,122,0)"/>
          <stop offset="100%" stop-color="rgba(78,207,122,0.18)"/>
        </linearGradient>
      </defs>

      <!-- outer glow -->
      <circle cx="160" cy="160" r="170" fill="url(#glowGrad)"/>
      <!-- background fill -->
      <circle cx="160" cy="160" r="144" fill="url(#bgGrad)"/>

      <g clip-path="url(#circle-clip)">
        <!-- ring circles -->
        <circle cx="160" cy="160" r="48" fill="none" stroke="rgba(78,207,122,0.13)" stroke-width="1"/>
        <circle cx="160" cy="160" r="81" fill="none" stroke="rgba(78,207,122,0.17)" stroke-width="1"/>
        <circle cx="160" cy="160" r="113" fill="none" stroke="rgba(78,207,122,0.20)" stroke-width="1"/>
        <circle cx="160" cy="160" r="144" fill="none" stroke="rgba(78,207,122,0.25)" stroke-width="1"/>

        <!-- crosshairs -->
        <line x1="16" y1="160" x2="304" y2="160" stroke="rgba(78,207,122,0.07)" stroke-width="0.5"/>
        <line x1="160" y1="16" x2="160" y2="304" stroke="rgba(78,207,122,0.07)" stroke-width="0.5"/>

        <!-- sweep trail — static wedge at ~45deg -->
        <path d="M160,160 L268,52 A144,144 0 0,0 160,16 Z" fill="rgba(78,207,122,0.06)"/>
        <path d="M160,160 L268,52 A144,144 0 0,0 220,22 Z" fill="rgba(78,207,122,0.06)"/>
        <path d="M160,160 L268,52 A144,144 0 0,0 244,34 Z" fill="rgba(78,207,122,0.05)"/>
        <path d="M160,160 L268,52 A144,144 0 0,0 258,44 Z" fill="rgba(78,207,122,0.04)"/>

        <!-- blips -->
        <circle cx="228" cy="96" r="4" fill="rgba(78,207,122,0.9)" filter="url(#blip-glow)"/>
        <circle cx="196" cy="130" r="3" fill="rgba(78,207,122,0.65)"/>
        <circle cx="110" cy="200" r="3.5" fill="rgba(78,207,122,0.45)"/>
        <circle cx="88" cy="120" r="2.5" fill="rgba(78,207,122,0.35)"/>
        <circle cx="200" cy="210" r="2" fill="rgba(78,207,122,0.3)"/>
      </g>

      <!-- sweep line -->
      <line x1="160" y1="160" x2="262" y2="58" stroke="rgba(78,207,122,0.92)" stroke-width="1.8" stroke-linecap="round"/>

      <!-- outer ring -->
      <circle cx="160" cy="160" r="144" fill="none" stroke="rgba(78,207,122,0.32)" stroke-width="1.5"/>

      <!-- center dot -->
      <circle cx="160" cy="160" r="5" fill="#4ecf7a"/>
    </svg>
  </div>

  <div class="url-strip">thepeptideradar.com</div>
</div>
</body>
</html>
