# Treat all images as binary so autocrlf can't corrupt them
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.webp binary
*.gif binary
*.pdf binary

# Normalise line endings for source
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
